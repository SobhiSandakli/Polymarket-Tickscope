# Build output
build/

# Data files — never commit raw tick data, journals, or databases.
# Live capture output lands in data/; only data/samples/ is committed —
# small curated datasets (one per market class) so every notebook runs
# end-to-end from a fresh clone.
data/*
!data/samples/
*.duckdb
*.duckdb.tmp

# Logs — runtime output only
logs/
*.log

# Python cache
__pycache__/
*.pyc
research_env/
.venv/
research/*.ipynb_checkpoints/
research/**/.ipynb_checkpoints/

# OS
.DS_Store

# Editor
.vscode/
.idea/
*.swp

# Private docs (not for repo)
CLAUDE.md
.devcontainer/
commands.txt
PLAN.md
ARCHITECTURE_WALKTHROUGH.md
AUDIT_FINDINGS.md
CPP_CAPTURE_WALKTHROUGH.md
LEARNING_PLAN.md

# Editor / tooling cache
.cache/
