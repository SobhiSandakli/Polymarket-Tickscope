# /etc/default/polymarket-bot
#
# Bot runtime parameters used by polymarket-bot.service.

# Initial USDC capital for paper mode.
BOT_CAPITAL=1000

# Discovery filter string.
# Keep quotes because this contains spaces.
BOT_FILTER="up or down"

# ── Live-mode secrets (only needed when the bot runs with --live) ─────────────
# Read from the environment, never passed on the command line (argv is visible
# via `ps` and saved in shell history). Uncomment and set for live trading.
# BOT_PRIV_KEY=0x...
# BOT_API_KEY=...
# BOT_API_SECRET=...
# BOT_PASSPHRASE=...
